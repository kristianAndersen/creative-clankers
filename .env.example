# Copy to .env.local and fill in. .env.local is gitignored — never commit a real key.
#
# --- Provider selection ---------------------------------------------------
# Which LLM provider the substitution agent uses. Default: google (Gemini).
# Set to "groq" to use Groq instead. No code change needed.
# AI_PROVIDER=google

# --- Google Gemini (default / recommended) --------------------------------
# Free key (no credit card): https://aistudio.google.com/apikey
# Most generous free tier for a tool-calling agent (15 RPM / 1M TPM / 1500 RPD).
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: override the model (default: gemini-2.5-flash)
# GOOGLE_MODEL=gemini-2.5-flash

# --- Groq (fallback) ------------------------------------------------------
# Free key (no credit card): https://console.groq.com/keys
# Used when AI_PROVIDER=groq. Note: free tier is 100k tokens/DAY — tight for a
# multi-step agent. Use llama-3.3-70b-versatile (NOT 8b-instant, which loops).
GROQ_API_KEY=
# Optional: override the model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
